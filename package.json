{
  "name": "road-to-wc-final",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "web:dev": "vite",
    "stack:up": "docker compose -f infra/local/docker-compose.yml up -d",
    "stack:down": "docker compose -f infra/local/docker-compose.yml down",
    "stack:logs": "docker compose -f infra/local/docker-compose.yml logs -f",
    "test": "vitest run",
    "test:all": "vitest run --workspace vitest.workspace.ts",
    "test:packages": "vitest run --workspace vitest.workspace.ts packages",
    "smoke:pipeline": "node scripts/smoke-pipeline.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:apis": "node scripts/test-all-apis.mjs",
    "test:sofascore6": "node scripts/test-sofascore6.mjs",
    "test:sofascore-rapid": "node scripts/test-sofascore-rapid.mjs",
    "test:football-prediction": "node scripts/test-football-prediction.mjs",
    "test:world-cup-history": "node scripts/test-world-cup-history.mjs",
    "test:wc2026-teams": "node scripts/test-wc2026-teams.mjs",
    "test:wc-live": "node scripts/test-wc-live.mjs",
    "test:zafronix": "node scripts/test-zafronix.mjs",
    "bootstrap:team-sofa-ids": "node scripts/bootstrap-team-sofa-ids.mjs",
    "test:rapidapi": "node scripts/test-rapidapi.mjs",
    "test:rapidapi:full": "node scripts/test-rapidapi-full.mjs",
    "test:rapidapi:proxy": "node scripts/test-rapidapi-full.mjs -- --proxy",
    "sync:api-flags": "node scripts/sync-api-flags.mjs",
    "version:show": "node scripts/version.mjs show",
    "version:build": "node scripts/version.mjs build",
    "version:patch": "node scripts/version.mjs patch",
    "version:minor": "node scripts/version.mjs minor",
    "version:major": "node scripts/version.mjs major",
    "version:log": "node scripts/version.mjs log",
    "version:sync-canvas": "node scripts/sync-release-canvas.mjs",
    "version:record-commit": "node scripts/version.mjs record-commit",
    "version:record-deploy": "node scripts/version.mjs deploy",
    "prepare": "node scripts/install-git-hooks.mjs",
    "generate:thirds": "node scripts/build-third-place-map.mjs",
    "dev:portal": "cd tools/api-portal && npm run dev",
    "portal:stop": "lsof -ti:4242,4243 | xargs kill -9 2>/dev/null || true",
    "sync-keys": "cd tools/api-portal && npm run sync-keys",
    "sync-keys:wc": "cd tools/api-portal && npm run sync-keys -- \"World Cup Tracker\"",
    "pull-envs": "cd tools/api-portal && npm run pull-envs",
    "seed-vault": "cd tools/api-portal && npm run seed",
    "dedupe-vault": "cd tools/api-portal && npm run dedupe",
    "mcp:zafronix": "node scripts/mcp-zafronix-config.mjs",
    "mcp:endpoints": "node scripts/mcp-endpoint-config.mjs",
    "env:sync-vercel": "node scripts/sync-vercel-env.mjs",
    "deploy:vercel": "npm run build && npx vercel deploy --prod --yes && node scripts/version.mjs deploy --message \"Production deploy via deploy:vercel\"",
    "ui:debug-sweep": "node scripts/ui-debug-sweep.mjs",
    "ui:debug-sync-canvas": "node scripts/sync-ui-debug-canvas.mjs",
    "server:dev": "node --experimental-vm-modules --loader ts-node/esm server/src/index.ts",
    "server:build": "tsc -p server/tsconfig.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "admin:dev": "cd apps/admin && npm run dev"
  },
  "dependencies": {
    "@wc2026/canonical": "file:packages/canonical",
    "@wc2026/identity": "file:packages/identity",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.62.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "bullmq": "^5.79.2",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.468.0",
    "prisma": "^7.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true
  }
}

{
  "name": "road-to-wc-final",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vite",
    "web:dev": "vite",
    "stack:up": "docker compose -f infra/local/docker-compose.yml up -d",
    "stack:wait": "node scripts/wait-for-stack.mjs",
    "stack:bootstrap": "pnpm stack:up && pnpm stack:wait && pnpm db:push && pnpm db:seed",
    "stack:down": "docker compose -f infra/local/docker-compose.yml down",
    "stack:logs": "docker compose -f infra/local/docker-compose.yml logs -f",
    "test": "vitest run",
    "pretest": "node scripts/ensure-generated-data.mjs",
    "test:rules-audit": "vitest run src/lib/__tests__/tournamentRulesAudit.test.ts --reporter=verbose",
    "test:all": "vitest run --config vitest.workspace.ts",
    "test:packages": "vitest run --config vitest.workspace.ts packages",
    "smoke:pipeline": "tsx scripts/smoke-pipeline.ts",
    "smoke:db": "node scripts/smoke-db.mjs",
    "smoke:stack": "node scripts/smoke-stack.mjs",
    "verify:db": "node scripts/verify-db.mjs",
    "db:seed": "node scripts/seed-identity.mjs --write",
    "worker:dev": "node scripts/run-server-dev.mjs --workers",
    "server:dev": "node scripts/run-server-dev.mjs",
    "server:dev:workers": "node scripts/run-server-dev.mjs --workers",
    "server:stop": "lsof -ti:3001 | xargs kill -9 2>/dev/null || true",
    "build": "node scripts/ensure-generated-data.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "test:apis": "node scripts/test-all-apis.mjs",
    "test:sofascore6": "node scripts/test-sofascore6.mjs",
    "test:sofascore-rapid": "node scripts/test-sofascore-rapid.mjs",
    "test:football-prediction": "node scripts/test-football-prediction.mjs",
    "test:footapi7": "node scripts/test-footapi7.mjs",
    "test:today-football-prediction": "node scripts/test-today-football-prediction.mjs",
    "test:flashlive": "node scripts/test-flashlive.mjs",
    "test:meteosource": "node scripts/test-meteosource-weather.mjs",
    "test:football-highlights": "node scripts/test-football-highlights.mjs",
    "test:pldata": "node scripts/test-pldata.mjs",
    "test:getty-images": "node scripts/test-getty-images.mjs",
    "test:fifa-football-data": "node scripts/test-fifa-football-data.mjs",
    "test:ai-sports-highlights": "node scripts/test-ai-sports-highlights.mjs",
    "test:allsportsapi2": "node scripts/test-allsportsapi2.mjs",
    "test:tvpro-api": "node scripts/test-tvpro-api.mjs",
    "test:youtube-match-videos": "node scripts/test-youtube-match-videos.mjs",
    "sync:match-schedule": "node scripts/sync-match-schedule-from-espn.mjs",
    "sync:player-database": "node scripts/sync-player-database.mjs",
    "sync:kamp-matches": "node scripts/sync-kamp-matches.mjs",
    "fifa:serve": "node --watch ../fifa-public-api-mcp/build/httpServer.js",
    "sync:paninarr": "node scripts/sync-paninarr-assets.mjs",
    "audit:espn": "node scripts/audit-espn-live.mjs",
    "test:world-cup-history": "node scripts/test-world-cup-history.mjs",
    "test:wc2026-teams": "node scripts/test-wc2026-teams.mjs",
    "test:wc-live": "node scripts/test-wc-live.mjs",
    "test:zafronix": "node scripts/test-zafronix.mjs",
    "bootstrap:team-sofa-ids": "node scripts/bootstrap-team-sofa-ids.mjs",
    "test:rapidapi": "node scripts/test-rapidapi.mjs",
    "test:rapidapi:full": "node scripts/test-rapidapi-full.mjs",
    "test:rapidapi:proxy": "node scripts/test-rapidapi-full.mjs -- --proxy",
    "sync:api-flags": "node scripts/sync-api-flags.mjs",
    "logos:sync": "node tools/sync-football-logos.mjs",
    "logos:validate": "node tools/validate-team-logos.mjs",
    "version:show": "node scripts/version.mjs show",
    "version:build": "node scripts/version.mjs build",
    "version:patch": "node scripts/version.mjs patch",
    "version:minor": "node scripts/version.mjs minor",
    "version:major": "node scripts/version.mjs major",
    "version:log": "node scripts/version.mjs log",
    "version:sync-canvas": "node scripts/sync-release-canvas.mjs",
    "version:record-commit": "node scripts/version.mjs record-commit",
    "version:record-deploy": "node scripts/version.mjs deploy",
    "prepare": "node scripts/install-git-hooks.mjs && prisma generate || true",
    "generate:thirds": "node scripts/build-third-place-map.mjs",
    "dev:portal": "cd tools/api-portal && npm run dev",
    "portal:stop": "lsof -ti:4242,4243 | xargs kill -9 2>/dev/null || true",
    "sync-keys": "cd tools/api-portal && npm run sync-keys",
    "sync-keys:wc": "cd tools/api-portal && npm run sync-keys -- \"World Cup Tracker\"",
    "pull-envs": "cd tools/api-portal && npm run pull-envs",
    "seed-vault": "cd tools/api-portal && npm run seed",
    "dedupe-vault": "cd tools/api-portal && npm run dedupe",
    "mcp:zafronix": "node scripts/mcp-zafronix-config.mjs",
    "mcp:endpoints": "node scripts/mcp-endpoint-config.mjs",
    "env:sync-vercel": "node scripts/sync-vercel-env.mjs",
    "deploy:vercel": "pnpm run build && pnpm exec vercel deploy --prod --yes && node scripts/version.mjs deploy --message \"Production deploy via deploy:vercel\"",
    "ui:debug-sweep": "node scripts/ui-debug-sweep.mjs",
    "ui:debug-sync-canvas": "node scripts/sync-ui-debug-canvas.mjs",
    "server:build": "tsc -p server/tsconfig.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "admin:dev": "pnpm --filter @wc2026/admin dev"
  },
  "dependencies": {
    "@clerk/backend": "^3.8.4",
    "@hono/node-server": "^1.19.14",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.62.0",
    "@types/pg": "^8.20.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@wc2026/canonical": "workspace:*",
    "@wc2026/identity": "workspace:*",
    "@wc2026/qualification": "workspace:*",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.468.0",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.22.4",
    "vite": "^6.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.3.0",
    "playwright": "^1.61.1",
    "typescript": "^5.7.2",
    "vercel": "^54.18.1",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true
  }
}

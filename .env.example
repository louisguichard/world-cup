NODE_ENV=development
LOG_LEVEL=debug

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/world_cup_engine
REDIS_URL=redis://localhost:6379

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=world-cup-engine
KAFKA_GROUP_ID=local-dev

NATS_URL=nats://localhost:4222

ESPN_API_BASE_URL=https://site.api.espn.com
FIFA_API_BASE_URL=https://www.fifa.com
ODDS_API_BASE_URL=https://api.the-odds-api.com
ODDS_API_KEY=replace-me
WEATHER_API_BASE_URL=https://api.open-meteo.com

ENABLE_REPLAY=true
ENABLE_SCENARIOS=true

# Admin correction APIs (Phase 5 — dev gate; replace with Clerk in production)
DEV_ADMIN_TOKEN=dev-admin-change-me

# Optional provider keys (copy to .env.local)
# VITE_RAPIDAPI_KEY=
# VITE_ZAFRONIX_API_KEY=

# Getty Images (RapidAPI raygorodskij V1) — also needs Getty developer credentials:
# GETTY_API_KEY=your_getty_api_key
# GETTY_API_SECRET=your_getty_api_secret
# GETTY_ACCESS_TOKEN=optional_cached_token

# YouTube match videos use RAPIDAPI_KEY for google-api31 + website-social-scraper-api.
# Subscribe to each RapidAPI product before enabling production probes.

# ── Sync local → Vercel ───────────────────────────────────────────────────
# npm run env:sync-vercel        # push keys to Production + Preview
# npm run deploy:vercel          # redeploy after env changes (VITE_* are build-time)

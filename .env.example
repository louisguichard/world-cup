# ── Required for live data (local + Vercel) ───────────────────────────────
# RapidAPI — one key for ESPN proxies, WC Live, SportAPI, SofaScore, etc.
# Server: RAPIDAPI_KEY (edge /api/* routes)  |  Client build: VITE_RAPIDAPI_KEY
VITE_RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_KEY=your_rapidapi_key_here

# Zafronix — H2H, bracket, team profiles (same RapidAPI key often works)
# Server: ZAFRONIX_API_KEY  |  Client build: VITE_ZAFRONIX_API_KEY
VITE_ZAFRONIX_API_KEY=your_zafronix_or_rapidapi_key_here
ZAFRONIX_API_KEY=your_zafronix_or_rapidapi_key_here

# ── Optional stubs (leave FILL_ME_IN until subscribed) ────────────────────
# VITE_THESTATS_API_KEY=FILL_ME_IN
# VITE_ODDS_API_KEY=FILL_ME_IN
# VITE_BETFAIR_SESSION_TOKEN=FILL_ME_IN
# VITE_SD_USERNAME=FILL_ME_IN

# Getty Images (RapidAPI raygorodskij V1) — also needs Getty developer credentials:
# GETTY_API_KEY=your_getty_api_key
# GETTY_API_SECRET=your_getty_api_secret
# GETTY_ACCESS_TOKEN=optional_cached_token

# YouTube match videos use RAPIDAPI_KEY for google-api31 + website-social-scraper-api.
# Subscribe to each RapidAPI product before enabling production probes.

# ── Sync local → Vercel ───────────────────────────────────────────────────
# npm run env:sync-vercel        # push keys to Production + Preview
# npm run deploy:vercel          # redeploy after env changes (VITE_* are build-time)

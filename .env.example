# RapidAPI — shared key for Free API Live Football Data (FotMob), SportAPI7,
#            WC 2026 Teams, WC 2026 Live, Open Weather 13, Sports Odds Intelligence,
#            and the RapidAPI MCP hub (dev + Vercel edge proxies + Cursor MCP)
VITE_RAPIDAPI_KEY=your_rapidapi_key_here

# Vercel server-side only (edge proxies inject this; do not prefix with VITE_)
# RAPIDAPI_KEY=your_rapidapi_key_here

# Zafronix — direct auth (X-API-Key header), separate from RapidAPI
VITE_ZAFRONIX_API_KEY=your_zafronix_key_here
# ZAFRONIX_API_KEY=your_zafronix_key_here

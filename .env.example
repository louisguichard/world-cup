# RapidAPI — one key for all subscribed hubs (browser + Vercel edge proxies)
VITE_RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional — Zafronix protected endpoints (H2H, bracket, team profiles) on RapidAPI hub

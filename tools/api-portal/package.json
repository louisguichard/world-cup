{
  "name": "api-vault-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build:server": "tsc -p tsconfig.server.json",
    "sync-keys": "tsx server/sync.ts",
    "seed": "tsx server/seed.ts",
    "dedupe": "tsx server/dedupe.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "keytar": "^7.9.0",
    "nanoid": "^5.0.7",
    "node-forge": "^1.3.1",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-forge": "^1.3.11",
    "concurrently": "^8.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "@vitejs/plugin-react": "^4.3.1"
  },
  "allowScripts": {
    "keytar@7.9.0": true,
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true
  }
}

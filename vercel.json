{
  "rewrites": [
    {
      "source": "/api/wc-live/:upstream*",
      "destination": "/api/rapid?service=wc-live"
    },
    {
      "source": "/api/wc2026/:upstream*",
      "destination": "/api/rapid?service=wc2026"
    },
    {
      "source": "/api/footballdata/:upstream*",
      "destination": "/api/rapid?service=footballdata"
    },
    {
      "source": "/api/sportapi/:upstream*",
      "destination": "/api/rapid?service=sportapi"
    },
    {
      "source": "/api/sofascore6/:upstream*",
      "destination": "/api/rapid?service=sofascore6"
    },
    {
      "source": "/api/sofascore-rapid/:upstream*",
      "destination": "/api/rapid?service=sofascore-rapid"
    },
    {
      "source": "/api/weather/:upstream*",
      "destination": "/api/rapid?service=weather"
    },
    {
      "source": "/api/odds/:upstream*",
      "destination": "/api/rapid?service=odds"
    },
    {
      "source": "/api/football-prediction/:upstream*",
      "destination": "/api/rapid?service=football-prediction"
    },
    {
      "source": "/api/world-cup-history/:upstream*",
      "destination": "/api/rapid?service=world-cup-history"
    },
    {
      "source": "/api/sport-highlights/:upstream*",
      "destination": "/api/rapid?service=sport-highlights"
    },
    {
      "source": "/api/sports-live-scores/:upstream*",
      "destination": "/api/rapid?service=sports-live-scores"
    },
    {
      "source": "/api/all-sport-live-stream/:upstream*",
      "destination": "/api/rapid?service=all-sport-live-stream"
    },
    {
      "source": "/api/free-daily-xtream-iptv/:upstream*",
      "destination": "/api/rapid?service=free-daily-xtream-iptv"
    },
    {
      "source": "/api/cloud-api-hub-iptv/:upstream*",
      "destination": "/api/rapid?service=cloud-api-hub-iptv"
    },
    {
      "source": "/api/tvview/:upstream*",
      "destination": "/api/rapid?service=tvview"
    },
    {
      "source": "/api/zafronix/:upstream*",
      "destination": "/api/rapid?service=zafronix"
    },
    {
      "source": "/api/espn-web/:upstream*",
      "destination": "/api/proxy"
    },
    {
      "source": "/espn/:path*",
      "destination": "https://site.api.espn.com/:path*"
    },
    {
      "source": "/espn-web/:path*",
      "destination": "https://site.web.api.espn.com/:path*"
    },
    {
      "source": "/poly/:path*",
      "destination": "https://gamma-api.polymarket.com/:path*"
    },
    {
      "source": "/fifa-api/:path*",
      "destination": "https://www.fifa.com/:path*"
    },
    {
      "source": "/fifa/:path*",
      "destination": "https://inside.fifa.com/:path*"
    },
    {
      "source": "/api/sofascore6/:path*",
      "destination": "/api/sofascore6/:path*"
    },
    {
      "source": "/api/sofascore/:path*",
      "destination": "/api/sofascore?path=:path*"
    },
    {
      "source": "/api/clubelo/:path*",
      "destination": "/api/clubelo"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; connect-src 'self' https://site.api.espn.com https://site.web.api.espn.com https://gamma-api.polymarket.com https://api.fifa.com https://www.fifa.com https://api.sofascore.com https://sofascore6.p.rapidapi.com http://api.clubelo.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'"
        }
      ]
    }
  ]
}

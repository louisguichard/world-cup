{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@wc2026/canonical": ["./packages/canonical/src/index.ts"],
      "@wc2026/events": ["./packages/events/src/index.ts"],
      "@wc2026/identity": ["./packages/identity/src/index.ts"],
      "@wc2026/qualification": ["./packages/qualification/src/index.ts"],
      "@wc2026/prediction": ["./packages/prediction/src/index.ts"],
      "@wc2026/zod-schemas": ["./packages/zod-schemas/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
